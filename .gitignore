# Covers JetBrains IDEs: IntelliJ, GoLand, RubyMine, PhpStorm, AppCode, PyCharm, CLion, Android Studio, WebStorm and Rider
# Reference: https://intellij-support.jetbrains.com/hc/en-us/articles/206544839

# User-specific stuff
code/.idea/**/workspace.xml
code/.idea/**/tasks.xml
code/.idea/**/usage.statistics.xml
code/.idea/**/dictionaries
code/.idea/**/shelf

# AWS User-specific
code/.idea/**/aws.xml

# Generated files
code/.idea/**/contentModel.xml

# Sensitive or high-churn files
code/.idea/**/dataSources/
code/.idea/**/dataSources.ids
code/.idea/**/dataSources.local.xml
code/.idea/**/sqlDataSources.xml
code/.idea/**/dynamic.xml
code/.idea/**/uiDesigner.xml
code/.idea/**/dbnavigator.xml

# Gradle
code/.idea/**/gradle.xml
code/.idea/**/libraries

# Gradle and Maven with auto-import
# When using Gradle or Maven with auto-import, you should exclude module files,
# since they will be recreated, and may cause churn.  Uncomment if using
# auto-import.
# code/.idea/artifacts
# code/.idea/compiler.xml
# code/.idea/jarRepositories.xml
# code/.idea/modules.xml
# code/.idea/*.iml
# code/.idea/modules
# *.iml
# *.ipr

# CMake
cmake-build-*/

# Mongo Explorer plugin
code/.idea/**/mongoSettings.xml

# File-based project format
*.iws

# IntelliJ
out/

# mpeltonen/sbt-idea plugin
code/.idea_modules/

# JIRA plugin
atlassian-ide-plugin.xml

# Cursive Clojure plugin
code/.idea/replstate.xml

# SonarLint plugin
code/.idea/sonarlint/
code/.idea/sonarlint.xml # see https://community.sonarsource.com/t/is-the-file-idea-idea-idea-sonarlint-xml-intended-to-be-under-source-control/121119

# Crashlytics plugin (for Android Studio and IntelliJ)
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# Editor-based HTTP Client
code/.idea/httpRequests
http-client.private.env.json

# Android studio 3.1+ serialized cache file
code/.idea/caches/build_file_checksums.ser

# Apifox Helper cache
code/.idea/.cache/.Apifox_Helper
code/.idea/ApifoxUploaderProjectSetting.xml

# Github Copilot persisted session migrations, see: https://github.com/microsoft/copilot-intellij-feedback/issues/712#issuecomment-3322062215
code/.idea/**/copilot.data.migration.*.xml
